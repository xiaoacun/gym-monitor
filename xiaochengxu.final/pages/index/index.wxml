<!-- index.wxml -->
<view class="page-container">

  <!-- 头部标题 -->
  <view class="header-container">
    <view class="header-title">健身房智能监控</view>
    <view class="header-status">
      <view class="status-dot {{online ? 'online' : 'offline'}}"></view>
      <view class="status-text">{{online ? '设备在线' : '设备离线'}}</view>
    </view>
  </view>

  <!-- 核心数据展示 -->
  <view class="people-card">
    <view class="people-count">{{currentPeople}}</view>
    <view class="people-label">当前人数</view>
    <view class="people-max">最大容量：{{maxPeople}}人</view>
    <!-- 进度条 -->
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progressPercent}}%"></view>
    </view>
  </view>

  <!-- 环境数据 -->
  <view class="section-title">环境监测</view>
  <view class="env-container">
    <view class="env-item">
      <image src="/图片/温度.png" class="env-icon" mode="aspectFit"/>
      <view class="env-info">
        <view class="env-value">{{temperature}}°C</view>
        <view class="env-label">温度</view>
      </view>
    </view>
    <view class="env-item">
      <image src="/图片/湿度.png" class="env-icon" mode="aspectFit"/>
      <view class="env-info">
        <view class="env-value">{{humidity}}%</view>
        <view class="env-label">湿度</view>
      </view>
    </view>
  </view>

  <!-- 器械状态 -->
  <view class="section-title">器械状态</view>
  <view class="equipment-container">
    <view class="equipment-item">
      <view class="equipment-item-left">
        <image src="/图片/设备状态.png" class="equipment-icon" mode="aspectFit"/>
        <view class="equipment-info">
          <view class="equipment-name">器械 1</view>
          <view class="equipment-stats">
            <text class="stat-text">10分钟: {{eq1Last10min}}次</text>
            <text class="stat-text">1小时: {{eq1Last1hour}}次</text>
          </view>
        </view>
      </view>
      <view class="equipment-right">
        <view class="equipment-status {{equipment1 ? 'occupied' : 'free'}}">
          {{equipment1 ? '使用中' : '空闲'}}
        </view>
        <view class="equipment-count">总计 {{equipment1Count}} 次</view>
      </view>
    </view>
    <view class="equipment-items">
      <view class="equipment-item-left">
        <image src="/图片/设备状态.png" class="equipment-icon" mode="aspectFit"/>
        <view class="equipment-info">
          <view class="equipment-name">器械 2</view>
          <view class="equipment-stats">
            <text class="stat-text">10分钟: {{eq2Last10min}}次</text>
            <text class="stat-text">1小时: {{eq2Last1hour}}次</text>
          </view>
        </view>
      </view>
      <view class="equipment-right">
        <view class="equipment-status {{equipment2 ? 'occupied' : 'free'}}">
          {{equipment2 ? '使用中' : '空闲'}}
        </view>
        <view class="equipment-count">总计 {{equipment2Count}} 次</view>
      </view>
    </view>
  </view>

  <!-- 今日预约状态（新增） -->
  <view class="section-title">今日预约状态</view>
  <view class="booking-container">
    <!-- 器械1预约 -->
    <view class="booking-equipment">
      <view class="booking-equipment-title">器械 1</view>
      <view class="time-slots">
        <view class="time-slot {{item.status === 'confirmed' ? 'booked' : 'available'}}" wx:for="{{equipment1Bookings}}" wx:key="startTime">
          <text class="slot-time">{{item.startTime}}-{{item.endTime}}</text>
          <text class="slot-status">{{item.status === 'confirmed' ? '已预约' : '待确认'}}</text>
        </view>
        <view class="no-booking" wx:if="{{equipment1Bookings.length === 0}}">暂无预约</view>
      </view>
    </view>
    <!-- 器械2预约 -->
    <view class="booking-equipment">
      <view class="booking-equipment-title">器械 2</view>
      <view class="time-slots">
        <view class="time-slot {{item.status === 'confirmed' ? 'booked' : 'available'}}" wx:for="{{equipment2Bookings}}" wx:key="startTime">
          <text class="slot-time">{{item.startTime}}-{{item.endTime}}</text>
          <text class="slot-status">{{item.status === 'confirmed' ? '已预约' : '待确认'}}</text>
        </view>
        <view class="no-booking" wx:if="{{equipment2Bookings.length === 0}}">暂无预约</view>
      </view>
    </view>
  </view>

  <!-- 重置按钮 -->
  <view class="reset-container">
    <button class="reset-btn" bindtap="resetPeopleCount">重置人数计数</button>
  </view>

  <!-- 注册提示 -->
  <view class="register-tip">
    <text class="tip-text">如需预约器械，请先在网页端注册账号</text>
  </view>

  <!-- 更新时间 -->
  <view class="update-time">最后更新：{{lastUpdateTime}}</view>

</view>
